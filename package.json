{
	"name": "animateicons-monorepo",
	"version": "0.1.0",
	"private": true,
	"packageManager": "pnpm@10.0.0",
	"scripts": {
		"format": "prettier --write .",
		"gen:icons-json": "tsx scripts/generate-icons-json.ts",
		"gen:registry": "tsx scripts/generate-registry.ts",
		"gen:catalog": "tsx scripts/generate-catalog.ts",
		"gen:icons": "pnpm run gen:icons-json && pnpm run gen:registry && pnpm run gen:catalog",
		"check:icons": "tsx scripts/check-duplicate-icons.ts",
		"check:registry": "tsx scripts/check-registry.ts",
		"check:all": "pnpm run format && pnpm run check:icons && pnpm run check:registry",
		"prebuild": "pnpm run gen:icons && pnpm run check:all",
		"dev": "pnpm run gen:icons && pnpm run check:all && next dev --turbopack",
		"build": "next build",
		"start": "next start",
		"lint": "echo \"lint disabled\" && exit 0",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"build:packages": "pnpm --filter @animateicons/core build && pnpm --filter animateicons build && pnpm --filter @animateicons/mcp build",
		"verify:packages": "pnpm --filter @animateicons/core verify && pnpm --filter animateicons verify && pnpm --filter @animateicons/mcp verify",
		"verify": "pnpm run check:all && pnpm run typecheck && pnpm run test && pnpm --filter @animateicons/react verify && pnpm run verify:packages",
		"ship": "pnpm run verify && pnpm run build",
		"changeset": "changeset",
		"changeset:version": "changeset version",
		"release:npm:patch": "pnpm --filter @animateicons/react release:patch && git push --follow-tags",
		"release:npm:minor": "pnpm --filter @animateicons/react release:minor && git push --follow-tags",
		"release:npm:major": "pnpm --filter @animateicons/react release:major && git push --follow-tags"
	},
	"dependencies": {
		"@mdx-js/loader": "^3.1.1",
		"@mdx-js/react": "^3.1.1",
		"@next/mdx": "^16.2.9",
		"@radix-ui/react-separator": "^1.1.10",
		"@radix-ui/react-tooltip": "^1.2.10",
		"@types/mdx": "^2.0.14",
		"@vercel/analytics": "^1.6.1",
		"babel-plugin-react-compiler": "^1.0.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"date-fns": "^4.4.0",
		"fuse.js": "^7.4.2",
		"lucide-react": "^0.564.0",
		"motion": "^12.40.0",
		"next": "^16.2.9",
		"radix-ui": "^1.6.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"shiki": "^3.23.0",
		"swr": "^2.4.1",
		"tailwind-merge": "^3.6.0",
		"use-debounce": "^10.1.1"
	},
	"devDependencies": {
		"@changesets/changelog-github": "^0.5.2",
		"@changesets/cli": "^2.31.0",
		"@tailwindcss/postcss": "^4.3.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^25.9.3",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.2.0",
		"baseline-browser-mapping": "^2.10.37",
		"jsdom": "^26.1.0",
		"prettier": "^3.8.4",
		"prettier-plugin-tailwindcss": "^0.7.4",
		"tailwindcss": "^4.3.1",
		"tsx": "^4.22.4",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vitest": "^3.2.6"
	}
}
