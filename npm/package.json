{
	"name": "@animateicons/react",
	"version": "0.3.4",
	"description": "Animated SVG icons for React with hover and imperative animation triggers. Built on motion/react.",
	"license": "MIT",
	"author": "Avijit Dey",
	"homepage": "https://animateicons.in",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Avijit07x/animateicons.git",
		"directory": "npm"
	},
	"bugs": {
		"url": "https://github.com/Avijit07x/animateicons/issues"
	},
	"keywords": [
		"icons",
		"animated icons",
		"animated svg",
		"react icons",
		"motion icons",
		"motion react",
		"svg icons",
		"lucide animated",
		"huge animated"
	],
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"module-sync": "./dist/index.js",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./lucide": {
			"types": "./dist/lucide.d.ts",
			"module-sync": "./dist/lucide.js",
			"import": "./dist/lucide.js",
			"require": "./dist/lucide.cjs"
		},
		"./huge": {
			"types": "./dist/huge.d.ts",
			"module-sync": "./dist/huge.js",
			"import": "./dist/huge.js",
			"require": "./dist/huge.cjs"
		},
		"./package.json": "./package.json"
	},
	"sideEffects": false,
	"files": [
		"dist/**/*.{js,cjs,d.ts,d.cts}",
		"CHANGELOG.md",
		"README.md",
		"LICENSE"
	],
	"engines": {
		"node": ">=18.17.0"
	},
	"scripts": {
		"gen": "node scripts/generate-exports.mjs",
		"normalize": "node scripts/normalize-icon-names.mjs",
		"normalize-handles": "node scripts/normalize-handle-names.mjs",
		"check:naming": "node scripts/check-icon-naming.mjs",
		"build": "pnpm run gen && tsup",
		"dev": "pnpm run gen && tsup --watch",
		"typecheck": "tsc --noEmit",
		"test:codegen": "node --test __tests__/generate-exports.test.mjs",
		"test:smoke": "node --test __tests__/consume.test.mjs",
		"size": "size-limit",
		"pack:check": "npm pack --dry-run",
		"verify": "pnpm run normalize && pnpm run check:naming && pnpm run typecheck && pnpm run build && pnpm run test:codegen && pnpm run test:smoke && pnpm run size",
		"release:patch": "pnpm version patch",
		"release:minor": "pnpm version minor",
		"release:major": "pnpm version major",
		"prepack": "pnpm run check:naming && pnpm run build && pnpm run test:codegen && pnpm run test:smoke && pnpm run size"
	},
	"size-limit": [
		{
			"name": "lucide (full barrel + LazyMotion domMin)",
			"path": "dist/lucide.js",
			"limit": "55 kB",
			"ignore": [
				"react",
				"react-dom"
			]
		},
		{
			"name": "huge (full barrel + LazyMotion domMin)",
			"path": "dist/huge.js",
			"limit": "40 kB",
			"ignore": [
				"react",
				"react-dom"
			]
		},
		{
			"name": "single icon (LazyMotion domMin)",
			"path": "dist/lucide.js",
			"import": "{ BellRingIcon }",
			"limit": "50 kB",
			"ignore": [
				"react",
				"react-dom"
			]
		}
	],
	"peerDependencies": {
		"react": "^18.0.0 || ^19.0.0",
		"react-dom": "^18.0.0 || ^19.0.0"
	},
	"devDependencies": {
		"@size-limit/preset-small-lib": "^11.1.6",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"motion": "^12.0.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"size-limit": "^11.1.6",
		"tsup": "^8.3.0",
		"typescript": "^5.9.3"
	},
	"publishConfig": {
		"access": "public"
	}
}
